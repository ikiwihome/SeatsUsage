# 火山引擎访问凭据。不要把真实 .env 提交到仓库。
VOLCENGINE_ACCESS_KEY_ID=your-access-key-id
VOLCENGINE_SECRET_ACCESS_KEY=your-secret-access-key

# 如果使用临时凭据，填写 SessionToken / SecurityToken。
# VOLCENGINE_SESSION_TOKEN=your-session-token

# 火山方舟 OpenAPI 配置。
ARK_REGION=cn-beijing
ARK_SERVICE=ark
ARK_OPENAPI_HOST=ark.cn-beijing.volcengineapi.com
ARK_OPENAPI_VERSION=2024-01-01
ARK_PROJECT_NAME=default
ARK_BIZ_INFO=Pro

# ListSeatInfos 分页大小，以及每次 ListSeatInfoUsages 包含的 SeatIDs 数量。
# 官方 API Explorer 标注 SeatIDs 单次最大长度为 1000。
ARK_PAGE_SIZE=1000
ARK_USAGE_BATCH_SIZE=1000

# 本地 API 端口。
PORT=8787
